# Environment Configuration (development or production)
ENVIRONMENT=development

# Skip the startup job scrape to avoid burning Anthropic credits on every restart.
# Manually refresh when needed: curl -X POST http://localhost:8000/api/refresh-cache-incremental
SKIP_STARTUP_SCRAPE=

# Auth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
CLAUDE_API_KEY=

# Clerk Auth (backend JWT verification)
# Same value as REACT_APP_CLERK_PUBLISHABLE_CLIENT_KEY
CLERK_PUBLISHABLE_KEY=

# Cache Configuration
REDIS_URL=redis://localhost:6379

# Stack Auth Configuration
STACK_AUTH_PROJECT_ID=
STACK_AUTH_PUBLISHABLE_CLIENT_KEY=
STACK_AUTH_SECRET_KEY=

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=